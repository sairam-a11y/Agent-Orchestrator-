# ── AI ────────────────────────────────
GEMINI_API_KEY=""

# ── Search ────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here   # optional, falls back to DDG

# ── Database ──────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentdb
REDIS_URL=redis://localhost:6379

# ── Vector DB ─────────────────────────
CHROMA_DIR=./chroma_db
# Or for Pinecone:
# PINECONE_API_KEY=...
# PINECONE_ENV=...

# ── Monitoring ────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=agentic-ai-platform
